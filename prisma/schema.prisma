generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Source {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  type             String   @default("wechat")
  platformCategory String   @map("platform_category") @default("wechat")
  identifier       String   @default("")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  articles Article[]

  @@map("sources")
}

model Article {
  id      Int    @id @default(autoincrement())
  sourceId Int   @map("source_id")
  title   String
  summary String @default("")
  content String @default("")
  originalUrl  String   @map("original_url")
  coverImage   String?  @map("cover_image")
  author       String   @default("")
  publishedAt  DateTime @map("published_at")
  crawledAt    DateTime @default(now()) @map("crawled_at")

  // AI 分析字段
  aiCategory      String @default("其他") @map("ai_category")
  aiSubcategory   String @default("") @map("ai_subcategory")
  aiTags          String @default("[]") @map("ai_tags")
  aiImportance    Int    @default(3) @map("ai_importance")
  aiAnalysisLevel Int    @default(0) @map("ai_analysis_level")
  aiBrief         String @default("") @map("ai_brief")

  // 活动专用字段
  eventTime         String? @map("event_time")
  eventLocation     String? @map("event_location")
  eventRegistration String? @map("event_registration")

  // 去重
  contentHash String @unique @map("content_hash")

  source Source @relation(fields: [sourceId], references: [id])

  @@index([aiCategory])
  @@index([sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([aiCategory, publishedAt(sort: Desc)])
  @@map("articles")
}

model Category {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  name       String
  icon       String  @default("")
  parentSlug String? @map("parent_slug")
  sortOrder  Int     @default(0) @map("sort_order")

  @@map("categories")
}
